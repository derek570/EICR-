{
  "name": "eicr_automation",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "main": "src/server.js",
  "workspaces": [
    "packages/*",
    "frontend",
    "web"
  ],
  "scripts": {
    "start": "node src/server.js",
    "test": "node --experimental-vm-modules node_modules/jest/bin/jest.js",
    "test:coverage": "node --experimental-vm-modules node_modules/jest/bin/jest.js --coverage",
    "lint": "eslint src/ packages/ --ext .js,.ts,.tsx",
    "format": "prettier --write \"src/**/*.js\" \"packages/**/*.ts\"",
    "prepare": "husky"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.74.0",
    "@aws-sdk/client-s3": "^3.500.0",
    "@aws-sdk/client-secrets-manager": "^3.500.0",
    "@aws-sdk/s3-request-presigner": "^3.500.0",
    "@sentry/node": "^10.38.0",
    "@sentry/profiling-node": "^10.38.0",
    "archiver": "^7.0.1",
    "bcryptjs": "^2.4.3",
    "bullmq": "^5.70.1",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "exceljs": "^4.4.0",
    "exifr": "^7.1.3",
    "express": "^4.18.2",
    "express-rate-limit": "^8.2.1",
    "googleapis": "^171.0.0",
    "heic-convert": "^2.1.0",
    "helmet": "^8.1.0",
    "hpp": "^0.2.3",
    "js-yaml": "^4.1.1",
    "ioredis": "^5.4.0",
    "jsonwebtoken": "^9.0.2",
    "multer": "^2.0.2",
    "nodemailer": "^7.0.13",
    "openai": "^4.0.0",
    "pg": "^8.11.3",
    "playwright": "^1.58.0",
    "sharp": "^0.33.0",
    "socket.io": "^4.8.3",
    "stripe": "^20.3.0",
    "swagger-ui-express": "^5.0.1",
    "undici": "^7.22.0",
    "web-push": "^3.6.7",
    "winston": "^3.19.0",
    "ws": "^8.19.0",
    "xlsx": "^0.18.5"
  },
  "lint-staged": {
    "src/**/*.js": [
      "eslint --fix",
      "prettier --write"
    ],
    "packages/**/*.{ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "frontend/src/**/*.{ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "web/**/*.{ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ]
  },
  "overrides": {
    "bn.js": ">=5.2.3"
  },
  "devDependencies": {
    "@eslint/js": "^9.14.0",
    "@typescript-eslint/eslint-plugin": "^8.56.0",
    "@typescript-eslint/parser": "^8.56.0",
    "eslint": "^9.39.3",
    "globals": "^17.3.0",
    "husky": "^9.1.7",
    "jest": "^29.7.0",
    "lint-staged": "^16.2.7",
    "msw": "^2.12.7",
    "prettier": "^3.8.1",
    "supertest": "^7.2.2"
  }
}
