# CertMate Environment Configuration
# Copy this to .env for local development

# ===== Server =====
APP_PORT=3000

# ===== AWS Secrets Manager =====
# In production (ECS): set to true — all API keys and DB creds loaded from Secrets Manager
# In local dev: set to false — use the values below
USE_AWS_SECRETS=false
AWS_REGION=eu-west-2

# ===== JWT Authentication =====
JWT_SECRET=your-secret-here-min-32-chars

# ===== Database =====
# Local dev: point to a local PostgreSQL instance
# Production: credentials come from AWS Secrets Manager (eicr/database)
DATABASE_TYPE=postgresql
DATABASE_URL=postgresql://eicr_dev:eicr_dev_password@localhost:5432/eicr_dev

# ===== Storage =====
# Local dev: use local filesystem (files saved to data/ directory)
# Production: set to s3 (bucket configured in AWS)
STORAGE_TYPE=local
# S3_BUCKET_NAME=eicr-files-production  # Only needed if STORAGE_TYPE=s3

# ===== Error Tracking (optional) =====
SENTRY_DSN=

# ===== Redis (optional) =====
# Only needed if running the job queue locally
REDIS_URL=redis://localhost:6379

# ===== API Keys (local dev only) =====
# In production these all live in a single AWS secret: eicr/api-keys (JSON)
# Uncomment and fill in for local development:
# OPENAI_API_KEY=sk-...
# GEMINI_API_KEY=...
# ANTHROPIC_API_KEY=sk-ant-...
# DEEPGRAM_API_KEY=...
# ELEVENLABS_API_KEY=...
