{
  "family": "eicr-backend",
  "networkMode": "awsvpc",
  "requiresCompatibilities": ["FARGATE"],
  "cpu": "512",
  "memory": "2048",
  "taskRoleArn": "arn:aws:iam::196390795898:role/eicr-ecs-task-role",
  "executionRoleArn": "arn:aws:iam::196390795898:role/eicr-ecs-execution-role",
  "runtimePlatform": {
    "cpuArchitecture": "ARM64",
    "operatingSystemFamily": "LINUX"
  },
  "volumes": [],
  "containerDefinitions": [
    {
      "name": "eicr-backend",
      "image": "196390795898.dkr.ecr.eu-west-2.amazonaws.com/eicr-backend:latest",
      "cpu": 0,
      "essential": true,
      "portMappings": [
        {
          "containerPort": 3000,
          "hostPort": 3000,
          "protocol": "tcp"
        }
      ],
      "environment": [
        { "name": "S3_BUCKET",          "value": "eicr-files-production" },
        { "name": "DATABASE_TYPE",      "value": "postgresql" },
        { "name": "AWS_REGION",         "value": "eu-west-2" },
        { "name": "PORT",               "value": "3000" },
        { "name": "USE_AWS_SECRETS",    "value": "true" },
        { "name": "NODE_ENV",           "value": "production" },
        { "name": "STORAGE_TYPE",       "value": "s3" },
        { "name": "REDIS_URL",          "value": "redis://eicr-redis-prod.k7wlgi.0001.euw2.cache.amazonaws.com:6379" },
        { "name": "SONNET_TOOL_CALLS",  "value": "live" },
        { "name": "CCU_STAGE2_GROUPS",  "value": "true" },
        { "name": "CCU_SLIDING_WINDOW", "value": "true" },
        { "name": "CCU_SLIDING_WINDOW_MODEL", "value": "gpt-5.5" },
        { "name": "CCU_USE_SINGLE_SHOT", "value": "true" },
        { "name": "STAGE0_BENCH",       "value": "1" },
        { "name": "VOICE_LATENCY_STREAM_CONFIRMATIONS", "value": "true" },
        { "name": "VOICE_LATENCY_SUPPRESSION",          "value": "false" },
        { "name": "VOICE_LATENCY_REGEX_FAST_TTS",       "value": "true" },
        { "name": "VOICE_LATENCY_STREAM_ASK_USER",      "value": "false" },
        { "name": "VOICE_LATENCY_USE_MULTI_CONTEXT",    "value": "true" },
        { "name": "VOICE_LATENCY_LOADED_BARREL",        "value": "true" },
        { "name": "VOICE_LATENCY_LOADED_BARREL_MAX_PER_TURN", "value": "12" },
        { "name": "VOICE_LATENCY_ROUND1_EARLY_TERMINATE", "value": "true" },
        { "name": "VOICE_LATENCY_ROUND1_MODEL",         "value": "" },
        { "name": "VOICE_LATENCY_KILL_SWITCH",          "value": "false" },
        { "name": "SNAPSHOT_FORMAT",                    "value": "split_blocks" },
        { "name": "CIRCUIT_ORDER",                      "value": "recent_3" },
        { "name": "SONNET_EXTRACT_MODEL",               "value": "claude-haiku-4-5-20251001" },
        { "name": "OBSERVATION_EXTRACT_MODEL",          "value": "claude-sonnet-4-6" }
      ],
      "mountPoints": [],
      "volumesFrom": [],
      "logConfiguration": {
        "logDriver": "awslogs",
        "options": {
          "awslogs-group": "/ecs/eicr/eicr-backend",
          "awslogs-region": "eu-west-2",
          "awslogs-stream-prefix": "ecs"
        }
      },
      "systemControls": []
    }
  ]
}
